{
  "manifest_version": 3,
  "name": "素心导航",
  "version": "1.1",
  "description": "一键收藏当前页面到素心导航首页，支持直接选择/新建分组",
  "permissions": ["activeTab", "tabs", "storage"],
  "content_scripts": [{
    "matches": ["file:///C:/Users/SUNHIY/Desktop/suxin-nav/index.html*"],
    "js": ["content.js"],
    "run_at": "document_idle"
  }],
  "action": {
    "default_popup": "popup.html",
    "default_title": "收藏到素心导航"
  }
}
